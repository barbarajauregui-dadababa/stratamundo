# Copy this file to .env.local and fill in the real values.
# .env.local is git-ignored — never commit real secrets.

# Supabase — from Project Settings > API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME

# Anthropic — from console.anthropic.com > Settings > API Keys
# Server-side only. Never prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
